cat("\n========== Stage 3: Index Return Value Validation ==========\n")
cz_idx <- mutateR:::ensure_crispritz_index(
genome    = genome,
nuclease  = "Cas9",
max_bulge = 2L,
cache_dir = cache_dir,
quiet     = FALSE
)
cat("indexed:                    ", cz_idx$indexed, "\n")
cat("index_dir:                  ", cz_idx$index_dir, "\n")
cat("Is TST subdir:              ", basename(cz_idx$index_dir) == tst_name, "\n")
cat("Dir exists:                 ", dir.exists(cz_idx$index_dir), "\n")
# Verify .bin files directly in returned directory
bin_count <- length(list.files(cz_idx$index_dir, pattern = "\\.bin$"))
cat(".bin file count:            ", bin_count, "\n")
# max_bulge=0 should still skip indexing
cat("\nmax_bulge=0 (should skip indexing):\n")
genome_dir <- mutateR:::ensure_genome_cache(genome, cache_dir, quiet = TRUE)
cz_skip <- mutateR:::ensure_crispritz_index(
genome = genome, nuclease = "Cas9", max_bulge = 0L,
cache_dir = cache_dir, quiet = TRUE
)
cat("  indexed:   ", cz_skip$indexed, " (expected FALSE)\n")
cat("  Returns FASTA dir: ", cz_skip$index_dir == genome_dir, " (expected TRUE)\n")
# max_bulge=1 should return bMax=1 index (Session 5 operational target)
cat("\nmax_bulge=1 (Session 5 operational target):\n")
cz_b1 <- mutateR:::ensure_crispritz_index(
genome = genome, nuclease = "Cas9", max_bulge = 1L,
cache_dir = cache_dir, quiet = FALSE
)
cat("  indexed:          ", cz_b1$indexed, " (expected TRUE)\n")
cat("  index_dir:        ", cz_b1$index_dir, "\n")
cat("  Points to bMax=1: ", grepl("_b1$", cz_b1$index_dir), " (expected TRUE)\n")
if (dir.exists(cz_b1$index_dir)) {
b1_bins <- length(list.files(cz_b1$index_dir, pattern = "\\.bin$"))
cat("  .bin files:       ", b1_bins, "\n")
}
t0 <- Sys.time()
result_hybrid <- tryCatch(
run_mutateR(
gene_id              = "TP53",
species              = "hsapiens",
genome               = genome,
nuclease             = "Cas9",
ot_backend           = "hybrid",
max_mismatches       = 3L,
max_dna_bulges       = 2L,
max_rna_bulges       = 2L,
ot_threads           = 4L,
ot_timeout           = 1800L,
offtarget            = TRUE,
ot_detail_level      = "compact",
min_pair_specificity = 10,
quiet                = FALSE
),
error = function(e) {
cat("PIPELINE ERROR: ", conditionMessage(e), "\n")
NULL
}
)
t1 <- Sys.time()
hybrid_time <- round(difftime(t1, t0, units = "mins"), 1)
cat("\nHybrid pipeline time: ", hybrid_time, " min\n")
if (!is.null(result_hybrid)) {
cat("ot_backend:        ", result_hybrid$ot_backend, "\n")
cat("Total pairs:       ", if (!is.null(result_hybrid$pairs)) nrow(result_hybrid$pairs) else 0, "\n")
cat("Recommended:       ", if (!is.null(result_hybrid$pairs)) sum(result_hybrid$pairs$recommended, na.rm = TRUE) else 0, "\n")
bulge_details <- attr(result_hybrid$scored_grnas, "bulge_offtarget_details")
cat("Bulge details attached: ", !is.null(bulge_details), "\n")
if (!is.null(bulge_details)) {
cat("Bulge detail rows:      ", nrow(bulge_details), "\n")
if (nrow(bulge_details) > 0 && "bulge_type" %in% names(bulge_details)) {
cat("Bulge type distribution:\n")
print(table(bulge_details$bulge_type))
}
}
cat("PASS: Hybrid pipeline completed.\n")
# Session 5 specific checks
cat("\n--- Session 5 Phase 2 validation (Hybrid) ---\n")
cat("Check messages above for:\n")
cat("  [✓] 'Phase 2 bulge search capped at bMax=1'\n")
cat("  [✓] Adaptive timeout in Phase 2 call\n")
cat("  [✓] Pipeline summary shows 'hybrid/two-phase (Phase2: bMax=1)'\n")
if (!is.null(bulge_details) && nrow(bulge_details) > 0) {
has_actual_bulges <- any(bulge_details$bulge_type %in% c("DNA", "RNA", "DNA+RNA"))
cat("Phase 2 found bulge off-targets: ", has_actual_bulges, "\n")
}
} else {
cat("FAIL: Hybrid pipeline did not complete.\n")
}
