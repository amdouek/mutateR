cz_cached <- mutateR:::ensure_crispritz_index(
genome = genome, nuclease = "Cas9", max_bulge = 2L,
cache_dir = cache_dir, quiet = TRUE
)
t1 <- Sys.time()
cat("\nPost-migration cache hit:\n")
cat("  Time:     ", round(difftime(t1, t0, units = "secs"), 3), "s\n")
cat("  Same dir: ", identical(cz_migrated$index_dir, cz_cached$index_dir), "\n")
cat("  indexed:  ", cz_cached$indexed, "\n")
}
